# =============================================================================
# DataForge ELT — environment template
# Copy to .env and fill in your values. Never commit .env.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=DataForge
DEBUG=false
ENVIRONMENT=development

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token_hex-48
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_ROTATION=5 MB
LOG_RETENTION=10 days

# ── Storage paths ─────────────────────────────────────────────────────────────
DATA_LAKE=./datalake
DUCKDB_PATH=./warehouse/data.duckdb
DBT_PROJECT_DIR=./dbt
DBT_PROFILES_DIR=./dbt

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_TIMEOUT=30
HEADLESS=true
MAX_RETRIES=3
RETRY_WAIT_MIN=1
RETRY_WAIT_MAX=30
RATE_LIMIT_RPS=1.0
ROBOTS_TXT_COMPLIANCE=true
SCREENSHOT_ON_FAILURE=true
SCREENSHOTS_DIR=./logs/screenshots

# ── Notifications (optional) ──────────────────────────────────────────────────
DISCORD_WEBHOOK=
SLACK_WEBHOOK=

# ── Email (optional) ──────────────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=dataforge@localhost
EMAIL_TO=

# ── Kaggle (required for Kaggle datasets) ────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── AWS S3 (optional — for remote parquet storage) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=dataforge-elt-storage

# ── MinIO (local dev alternative to S3) ──────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dataforge

# ── Supabase (optional — storage + Postgres) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=dataforge-elt-bucket

# ── PostgreSQL (optional — Supabase or standalone Postgres) ───────────────────
DATABASE_URL=

# ── MongoDB (optional — raw document store for crawl results) ─────────────────
MONGODB_URL=
MONGODB_DB=dataforge_elt

# ── LLM / AI (optional) ───────────────────────────────────────────────────────
GROQ_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
